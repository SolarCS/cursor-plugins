# Set before starting Cursor (macOS):
#   launchctl setenv SF_CLIENT_ID "..."
#   launchctl setenv GOOGLE_MCP_CLIENT_ID "..."
#   launchctl setenv GOOGLE_MCP_CLIENT_SECRET "..."
# Then Cmd+Q Cursor and reopen.
#
# One Google OAuth app typically covers Calendar, Gmail, and Drive MCP.

SF_CLIENT_ID=your_salesforce_consumer_key

GOOGLE_MCP_CLIENT_ID=your_google_oauth_client_id
GOOGLE_MCP_CLIENT_SECRET=your_google_oauth_client_secret
