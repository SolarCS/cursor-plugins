# Seismic MCP OAuth credentials (required before opening Cursor)
#   launchctl setenv SEISMIC_MCP_CLIENT_ID "..."
#   launchctl setenv SEISMIC_MCP_CLIENT_SECRET "..."   # if your Seismic app uses a client secret
# Then Cmd+Q Cursor and reopen, then Connect in Settings → Tools & MCP.
#
# Create the app at https://apps.seismic.com (MCP-type app) and register this redirect URI:
#   cursor://anysphere.cursor-mcp/oauth/callback
#
# A Seismic tenant admin must enable the app under System Settings → My Apps.

SEISMIC_MCP_CLIENT_ID=your_seismic_app_client_id
SEISMIC_MCP_CLIENT_SECRET=your_seismic_app_client_secret
