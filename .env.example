# Set before starting Cursor (macOS):
#   launchctl setenv SF_CLIENT_ID "..."
#   launchctl setenv GOOGLE_CALENDAR_CLIENT_ID "..."
#   launchctl setenv GOOGLE_CALENDAR_CLIENT_SECRET "..."
# Then Cmd+Q Cursor and reopen.

SF_CLIENT_ID=your_salesforce_consumer_key

GOOGLE_CALENDAR_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_oauth_client_secret
